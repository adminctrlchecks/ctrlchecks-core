# ──────────────────────────────────────────────────────────────────────────────
# CtrlChecks Worker — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# Vars marked [REQUIRED] cause process.exit(1) if missing at startup.
# Vars marked [OPTIONAL] degrade functionality when absent but do not crash.
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development                        # development | production | test
PORT=3001
PUBLIC_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080          # [OPTIONAL] Used for CORS allowlist
ALLOWED_ORIGINS=                            # [OPTIONAL] Comma-separated extra CORS origins

# ── AWS / Database ────────────────────────────────────────────────────────────
AWS_REGION=us-east-1                        # [REQUIRED]
AWS_ACCESS_KEY_ID=                          # [REQUIRED] IAM key for S3/SES/etc.
AWS_SECRET_ACCESS_KEY=                      # [REQUIRED]
DATABASE_URL=                               # [REQUIRED] postgresql://user:pass@host:5432/db
PGBOUNCER_URL=                              # [OPTIONAL] Use port 6432 when PgBouncer is active; falls back to DATABASE_URL
DIRECT_DATABASE_URL=                        # [OPTIONAL] Direct RDS connection (bypasses PgBouncer for migrations)

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379            # [REQUIRED] Rate limiting, sessions, execution queue, WS bridge

# ── Cognito Auth ──────────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=                       # [REQUIRED]
COGNITO_CLIENT_ID=                          # [REQUIRED]
COGNITO_ISSUER=                             # [REQUIRED] e.g. https://cognito-idp.us-east-1.amazonaws.com/<pool-id>
COGNITO_DOMAIN=                             # [OPTIONAL] e.g. auth.ctrlchecks.auth.us-east-1.amazoncognito.com
COGNITO_ADMIN_CLIENT_ID=                    # [OPTIONAL] Machine-to-machine admin operations
COGNITO_CLIENT_SECRET=                      # [OPTIONAL] Required for confidential clients

# ── AI — Gemini (primary) ─────────────────────────────────────────────────────
GEMINI_API_KEY=                             # [REQUIRED] Single key; set GEMINI_API_KEYS for multi-key pool
GEMINI_API_KEYS=                            # [OPTIONAL] Comma-separated pool of keys for rotation
GEMINI_KEY_COOLDOWN_SECONDS=60             # [OPTIONAL] Cooldown after rate-limit hit
GEMINI_MAX_RETRIES=2                        # [OPTIONAL]

# ── AI — Other providers ──────────────────────────────────────────────────────
OPENAI_API_KEY=                             # [OPTIONAL]
ANTHROPIC_API_KEY=                          # [OPTIONAL]
HUGGINGFACE_API_KEY=                        # [OPTIONAL]
GOOGLE_GEMINI_API_KEY=                      # [OPTIONAL] Legacy alias for GEMINI_API_KEY

# ── AI Generator Service ──────────────────────────────────────────────────────
AI_GENERATOR_URL=                           # [OPTIONAL] e.g. http://localhost:3002 — enables remote AI pipeline
AI_GENERATOR_SERVICE_KEY=                   # [OPTIONAL] Shared secret for service-to-service auth

# ── Execution Engine Service ──────────────────────────────────────────────────
EXECUTION_ENGINE_ENABLED=false              # [REQUIRED] false = use monolith; true = delegate to execution-engine:3003
EXECUTION_ENGINE_URL=http://localhost:3003  # [OPTIONAL] Override if service runs on a different host/port
EXECUTION_ENGINE_SERVICE_KEY=              # [OPTIONAL] Shared secret matching execution-engine EXECUTION_ENGINE_SERVICE_KEY
EXECUTION_ENGINE_CANARY_PERCENT=50         # [OPTIONAL] % of executions routed to engine (0–100). Phase4=50, Phase5=100. Circuit breaker opens at 3/5 failures.
WORKER_INTERNAL_KEY=                       # [OPTIONAL] Shared secret for engine→worker internal calls (must match engine WORKER_INTERNAL_KEY)

# ── Notification Service (:3005) ─────────────────────────────────────────────
NOTIFICATION_SERVICE_ENABLED=false         # [OPTIONAL] false = worker email-service.ts; true = delegate to notification-service:3005
NOTIFICATION_SERVICE_URL=http://localhost:3005  # [OPTIONAL] Override if service runs on a different host/port
NOTIFICATION_SERVICE_KEY=                  # [OPTIONAL] Shared secret matching notification-service NOTIFICATION_SERVICE_KEY
NOTIFICATION_SERVICE_CANARY_PERCENT=100    # [OPTIONAL] % 0–100. Phase4=100 (circuit breaker is monolith fallback). Emergency rollback: set 0.

# ── Trigger Service (:3006) ──────────────────────────────────────────────────
TRIGGER_SERVICE_ENABLED=false              # [OPTIONAL] false = worker trigger handlers; true = delegate to trigger-service:3006
TRIGGER_SERVICE_URL=http://localhost:3006  # [OPTIONAL] Override if service runs on a different host/port
TRIGGER_SERVICE_KEY=                       # [OPTIONAL] Shared secret matching trigger-service TRIGGER_SERVICE_KEY
TRIGGER_SERVICE_CANARY_PERCENT=100         # [OPTIONAL] % 0–100. Phase4=100 (circuit breaker is monolith fallback). Emergency rollback: set 0.

# ── Workflow CRUD Service (:3007) ────────────────────────────────────────────
WORKFLOW_CRUD_SERVICE_ENABLED=false              # [OPTIONAL] false = worker save-workflow.ts; true = delegate to workflow-crud-service:3007
WORKFLOW_CRUD_SERVICE_URL=http://localhost:3007  # [OPTIONAL] Override if service runs on a different host/port
WORKFLOW_CRUD_SERVICE_KEY=                       # [OPTIONAL] Shared secret matching workflow-crud-service WORKFLOW_CRUD_SERVICE_KEY
WORKFLOW_CRUD_SERVICE_CANARY_PERCENT=0           # [OPTIONAL] % 0–100. Default 0. Set 50=Phase2-staging, 100=Phase2-full
WORKFLOW_CRUD_LOCAL_WRITES_DISABLED=false        # [OPTIONAL] Phase 4 gate — set true only after 2-week soak at CANARY=100

# ── Credential Service (:3004) ────────────────────────────────────────────────
CREDENTIAL_SERVICE_ENABLED=false           # [OPTIONAL] false = use worker vault; true = delegate to credential-service:3004
CREDENTIAL_SERVICE_URL=http://localhost:3004  # [OPTIONAL] Override if service runs on a different host/port
CREDENTIAL_SERVICE_KEY=                    # [OPTIONAL] Shared secret matching credential-service CREDENTIAL_SERVICE_KEY
CREDENTIAL_SERVICE_CANARY_PERCENT=0        # [OPTIONAL] % 0–100. Default 0. Set 50=Phase2-staging, 100=Phase2-full
CREDENTIAL_SERVICE_OAUTH_ENABLED=false     # [OPTIONAL] false = local OAuth handlers; true = proxy to credential-service
CREDENTIAL_SERVICE_OAUTH_PROVIDERS=google,github,linkedin,notion,twitter,facebook,slack,hubspot,salesforce  # [OPTIONAL] comma-sep providers or "*" for all (Phase 4)
CREDENTIAL_SERVICE_VAULT_WRITES_DISABLED=false  # [OPTIONAL] After 2-week CRUD soak at CANARY=100, set true to retire worker vault writes

# ── Payments — Razorpay ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=                            # [OPTIONAL] Required for subscription features
RAZORPAY_KEY_SECRET=                        # [OPTIONAL]
RAZORPAY_WEBHOOK_SECRET=                    # [OPTIONAL]

# ── Email — AWS SES ───────────────────────────────────────────────────────────
SES_FROM_EMAIL=                             # [OPTIONAL] e.g. noreply@ctrlchecks.ai
SES_REGION=                                 # [OPTIONAL] Defaults to AWS_REGION if not set

# ── Error Tracking — Sentry ───────────────────────────────────────────────────
SENTRY_DSN=                                 # [OPTIONAL] Sentry DSN — enables error tracking (Task 7)
EXECUTION_EMAIL_NOTIFICATIONS=false         # [OPTIONAL] Set to "true" to email users on execution complete/fail

# ── Execution Queue ───────────────────────────────────────────────────────────
ENABLE_EXECUTION_QUEUE=true                 # [OPTIONAL] Enable async Redis-backed execution
WORKFLOW_WORKER_CONCURRENCY=5              # [OPTIONAL] Parallel job slots
WEBSOCKET_REDIS_CHANNEL_PREFIX=ws:exec:   # [OPTIONAL]

# ── OAuth Redirect URIs ───────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/oauth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://127.0.0.1:3001/api/oauth/github/callback
GITHUB_OAUTH_OMIT_REDIRECT_URI=false

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_OAUTH_REDIRECT_URI=http://localhost:3001/api/oauth/linkedin/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:3001/api/oauth/facebook/callback
META_APP_ID=
META_APP_SECRET=
META_FACEBOOK_CONFIG_ID=
META_FACEBOOK_EXTRA_SCOPES=

NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_REDIRECT_URI=http://localhost:8080/auth/notion/callback

TWITTER_OAUTH_CLIENT_ID=
TWITTER_OAUTH_CLIENT_SECRET=
TWITTER_OAUTH_REDIRECT_URI=http://localhost:8080/auth/twitter/callback
TWITTER_OAUTH_SCOPES=

INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_OAUTH_REDIRECT_URI=http://localhost:8080/auth/instagram/callback

WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_OAUTH_REDIRECT_URI=http://localhost:8080/auth/whatsapp/callback

SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_OAUTH_REDIRECT_URI=http://localhost:8080/auth/salesforce/callback

ZOHO_OAUTH_CLIENT_ID=
ZOHO_OAUTH_CLIENT_SECRET=
ZOHO_OAUTH_REDIRECT_URI=http://localhost:8080/auth/zoho/callback

# ── Security / Encryption ─────────────────────────────────────────────────────
CREDENTIAL_ENCRYPTION_KEY=                  # [OPTIONAL] AES key for credential vault encryption
ENCRYPTION_KEY=                             # [OPTIONAL] General-purpose encryption key
JWT_SECRET=                                 # [OPTIONAL] JWT signing secret

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_SCHEDULER=true
ENABLE_VECTOR_SEARCH=false
ENABLE_MEMORY_LOGGING=false
ENABLE_EVENT_LOGGING=false
DISABLE_JAVASCRIPT_NODE=false
SUBSCRIPTION_MODE=development               # development | production

# ── Tuning / Ops ─────────────────────────────────────────────────────────────
LOG_LEVEL=info                              # debug | info | warn | error
RATE_LIMIT_PER_MINUTE=60
EXECUTION_RETENTION_DAYS=30
WORKFLOW_RETENTION_DAYS=90
PROCESS_TIMEOUT_SECONDS=300
