{
  "name": "Test Dropbox — List + Upload + Download",
  "description": "Tests listing Dropbox files, uploading a test file, and downloading it back. Requires Dropbox account connected in /connections.",
  "nodes": [
    {
      "id": "node_1",
      "type": "custom",
      "position": { "x": 100, "y": 300 },
      "data": {
        "type": "manual_trigger",
        "label": "Start Test",
        "category": "triggers",
        "icon": "Play",
        "config": {}
      }
    },
    {
      "id": "node_2",
      "type": "custom",
      "position": { "x": 400, "y": 150 },
      "data": {
        "type": "dropbox",
        "label": "Dropbox — List Root Folder",
        "category": "storage",
        "icon": "Folder",
        "config": {
          "operation": "list",
          "path": "",
          "recursive": false,
          "limit": 20
        }
      }
    },
    {
      "id": "node_3",
      "type": "custom",
      "position": { "x": 700, "y": 150 },
      "data": {
        "type": "log_output",
        "label": "Log: List Result",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Dropbox List → entries={{$json.entries.length}} | has_more={{$json.has_more}} | first entry={{$json.entries[0].name}}"
        }
      }
    },
    {
      "id": "node_4",
      "type": "custom",
      "position": { "x": 400, "y": 350 },
      "data": {
        "type": "dropbox",
        "label": "Dropbox — Upload Test File",
        "category": "storage",
        "icon": "Upload",
        "config": {
          "operation": "upload",
          "path": "/ctrlchecks_test_upload.txt",
          "content": "This is a test file uploaded by ctrlchecks workflow platform. Safe to delete.",
          "mode": "overwrite",
          "autorename": false
        }
      }
    },
    {
      "id": "node_5",
      "type": "custom",
      "position": { "x": 700, "y": 350 },
      "data": {
        "type": "log_output",
        "label": "Log: Upload Result",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Dropbox Upload → path={{$json.path_display}} | id={{$json.id}} | size={{$json.size}}"
        }
      }
    },
    {
      "id": "node_6",
      "type": "custom",
      "position": { "x": 400, "y": 550 },
      "data": {
        "type": "dropbox",
        "label": "Dropbox — Download Test File",
        "category": "storage",
        "icon": "Download",
        "config": {
          "operation": "download",
          "path": "/ctrlchecks_test_upload.txt"
        }
      }
    },
    {
      "id": "node_7",
      "type": "custom",
      "position": { "x": 700, "y": 550 },
      "data": {
        "type": "log_output",
        "label": "Log: Download Result",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Dropbox Download → path={{$json.path_display}} | content received"
        }
      }
    }
  ],
  "edges": [
    { "id": "edge_1", "source": "node_1", "target": "node_2" },
    { "id": "edge_2", "source": "node_2", "target": "node_3" },
    { "id": "edge_3", "source": "node_1", "target": "node_4" },
    { "id": "edge_4", "source": "node_4", "target": "node_5" },
    { "id": "edge_5", "source": "node_4", "target": "node_6" },
    { "id": "edge_6", "source": "node_6", "target": "node_7" }
  ],
  "viewport": { "x": 0, "y": 0, "zoom": 0.85 }
}
