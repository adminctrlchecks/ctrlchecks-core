{
  "name": "Test OneDrive — List + Upload",
  "description": "Tests listing OneDrive files and uploading a test file. Requires Microsoft account connected in /connections.",
  "nodes": [
    {
      "id": "node_1",
      "type": "custom",
      "position": { "x": 100, "y": 250 },
      "data": {
        "type": "manual_trigger",
        "label": "Start Test",
        "category": "triggers",
        "icon": "Play",
        "config": {}
      }
    },
    {
      "id": "node_2",
      "type": "custom",
      "position": { "x": 400, "y": 150 },
      "data": {
        "type": "onedrive",
        "label": "OneDrive — List Root Files",
        "category": "storage",
        "icon": "HardDrive",
        "config": {
          "operation": "list",
          "path": "/",
          "limit": 20
        }
      }
    },
    {
      "id": "node_3",
      "type": "custom",
      "position": { "x": 700, "y": 150 },
      "data": {
        "type": "log_output",
        "label": "Log: List Result",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "OneDrive List → files={{$json.value.length}} | first file: {{$json.value[0].name}}"
        }
      }
    },
    {
      "id": "node_4",
      "type": "custom",
      "position": { "x": 400, "y": 350 },
      "data": {
        "type": "onedrive",
        "label": "OneDrive — Upload Test File",
        "category": "storage",
        "icon": "Upload",
        "config": {
          "operation": "upload",
          "path": "/ctrlchecks_test_upload.txt",
          "content": "This is a test file uploaded by ctrlchecks workflow platform. Safe to delete.",
          "mimeType": "text/plain"
        }
      }
    },
    {
      "id": "node_5",
      "type": "custom",
      "position": { "x": 700, "y": 350 },
      "data": {
        "type": "log_output",
        "label": "Log: Upload Result",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "OneDrive Upload → id={{$json.id}} | name={{$json.name}} | size={{$json.size}} | webUrl={{$json.webUrl}}"
        }
      }
    }
  ],
  "edges": [
    { "id": "edge_1", "source": "node_1", "target": "node_2" },
    { "id": "edge_2", "source": "node_2", "target": "node_3" },
    { "id": "edge_3", "source": "node_1", "target": "node_4" },
    { "id": "edge_4", "source": "node_4", "target": "node_5" }
  ],
  "viewport": { "x": 0, "y": 0, "zoom": 0.9 }
}
