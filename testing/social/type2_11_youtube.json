{
  "name": "Test YouTube - Supported OAuth Operations",
  "description": "Tests safe YouTube read operations using the user's connected YouTube OAuth2 account. Upload Video is implemented but intentionally excluded from this default workflow because it publishes real video content; test upload separately with privacyStatus=private or unlisted.",
  "nodes": [
    {
      "id": "node_1",
      "type": "custom",
      "position": { "x": 100, "y": 260 },
      "data": {
        "type": "manual_trigger",
        "label": "Start Test",
        "category": "triggers",
        "icon": "Play",
        "config": {}
      }
    },
    {
      "id": "node_2",
      "type": "custom",
      "position": { "x": 420, "y": 120 },
      "data": {
        "type": "youtube",
        "label": "YouTube - List My Channels",
        "category": "social",
        "icon": "Youtube",
        "config": {
          "operation": "list_my_channels",
          "maxResults": 10
        }
      }
    },
    {
      "id": "node_3",
      "type": "custom",
      "position": { "x": 760, "y": 120 },
      "data": {
        "type": "log_output",
        "label": "Log Channels",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "YouTube channels count={{$json.pageInfo.totalResults}} first={{$json.items[0].snippet.title}} channelId={{$json.items[0].id}}"
        }
      }
    },
    {
      "id": "node_4",
      "type": "custom",
      "position": { "x": 420, "y": 330 },
      "data": {
        "type": "youtube",
        "label": "YouTube - Search Videos",
        "category": "social",
        "icon": "Search",
        "config": {
          "operation": "search_videos",
          "query": "workflow automation",
          "maxResults": 5
        }
      }
    },
    {
      "id": "node_5",
      "type": "custom",
      "position": { "x": 760, "y": 330 },
      "data": {
        "type": "log_output",
        "label": "Log Search",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "YouTube search count={{$json.pageInfo.totalResults}} first={{$json.items[0].snippet.title}} videoId={{$json.items[0].id.videoId}}"
        }
      }
    },
    {
      "id": "node_6",
      "type": "custom",
      "position": { "x": 420, "y": 540 },
      "data": {
        "type": "youtube",
        "label": "YouTube - Get Video Statistics",
        "category": "social",
        "icon": "BarChart3",
        "config": {
          "operation": "get_video_stats",
          "videoId": "dQw4w9WgXcQ"
        }
      }
    },
    {
      "id": "node_7",
      "type": "custom",
      "position": { "x": 760, "y": 540 },
      "data": {
        "type": "log_output",
        "label": "Log Stats",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "YouTube stats title={{$json.title}} views={{$json.statistics.viewCount}} likes={{$json.statistics.likeCount}}"
        }
      }
    }
  ],
  "edges": [
    { "id": "edge_1", "source": "node_1", "target": "node_2" },
    { "id": "edge_2", "source": "node_2", "target": "node_3" },
    { "id": "edge_3", "source": "node_1", "target": "node_4" },
    { "id": "edge_4", "source": "node_4", "target": "node_5" },
    { "id": "edge_5", "source": "node_1", "target": "node_6" },
    { "id": "edge_6", "source": "node_6", "target": "node_7" }
  ],
  "viewport": { "x": 0, "y": 0, "zoom": 0.85 }
}
