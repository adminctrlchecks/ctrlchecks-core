{
  "name": "Test LinkedIn - Supported Member Operations",
  "description": "Tests LinkedIn operations currently exposed in the UI for the standard Sign In + Share app: get profile, create text post, create media post dry run, create article dry run, and delete the created text post.",
  "nodes": [
    {
      "id": "node_1",
      "type": "custom",
      "position": { "x": 100, "y": 350 },
      "data": {
        "type": "manual_trigger",
        "label": "Start Test",
        "category": "triggers",
        "icon": "Play",
        "config": {}
      }
    },
    {
      "id": "node_2",
      "type": "custom",
      "position": { "x": 400, "y": 100 },
      "data": {
        "type": "linkedin",
        "label": "LinkedIn - Get My Profile",
        "category": "social",
        "icon": "Linkedin",
        "config": {
          "operation": "get_profile"
        }
      }
    },
    {
      "id": "node_3",
      "type": "custom",
      "position": { "x": 700, "y": 100 },
      "data": {
        "type": "log_output",
        "label": "Log Profile",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "LinkedIn profile: id={{$json.profile.personUrn}} name={{$json.profile.name}} email={{$json.profile.email}}"
        }
      }
    },
    {
      "id": "node_4",
      "type": "custom",
      "position": { "x": 400, "y": 250 },
      "data": {
        "type": "linkedin",
        "label": "LinkedIn - Create Text Post",
        "category": "social",
        "icon": "PenTool",
        "config": {
          "operation": "create_post",
          "text": "Testing CtrlChecks workflow automation. This post will be deleted by the next test step.",
          "visibility": "PUBLIC",
          "dryRun": false
        }
      }
    },
    {
      "id": "node_5",
      "type": "custom",
      "position": { "x": 700, "y": 250 },
      "data": {
        "type": "log_output",
        "label": "Log Created Post",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "LinkedIn text post created: postId={{$json.postId}} success={{$json.success}}"
        }
      }
    },
    {
      "id": "node_6",
      "type": "custom",
      "position": { "x": 1000, "y": 250 },
      "data": {
        "type": "linkedin",
        "label": "LinkedIn - Delete Created Post",
        "category": "social",
        "icon": "Trash2",
        "config": {
          "operation": "delete_post",
          "postId": "{{$json.postId}}",
          "dryRun": false
        }
      }
    },
    {
      "id": "node_7",
      "type": "custom",
      "position": { "x": 1300, "y": 250 },
      "data": {
        "type": "log_output",
        "label": "Log Deleted Post",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "LinkedIn post delete result: success={{$json.success}} message={{$json.message}}"
        }
      }
    },
    {
      "id": "node_8",
      "type": "custom",
      "position": { "x": 400, "y": 450 },
      "data": {
        "type": "linkedin",
        "label": "LinkedIn - Create Media Post Dry Run",
        "category": "social",
        "icon": "Image",
        "config": {
          "operation": "create_post_media",
          "text": "Testing CtrlChecks LinkedIn media post payload.",
          "mediaUrl": "https://via.placeholder.com/1200x630.png?text=CtrlChecks+LinkedIn+Test",
          "visibility": "PUBLIC",
          "dryRun": true
        }
      }
    },
    {
      "id": "node_9",
      "type": "custom",
      "position": { "x": 700, "y": 450 },
      "data": {
        "type": "log_output",
        "label": "Log Media Dry Run",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "LinkedIn media dry run: success={{$json.success}} dryRun={{$json.dryRun}}"
        }
      }
    },
    {
      "id": "node_10",
      "type": "custom",
      "position": { "x": 400, "y": 650 },
      "data": {
        "type": "linkedin",
        "label": "LinkedIn - Create Article Dry Run",
        "category": "social",
        "icon": "FileText",
        "config": {
          "operation": "create_article",
          "text": "Testing CtrlChecks LinkedIn article share payload.",
          "articleUrl": "https://www.linkedin.com/",
          "visibility": "PUBLIC",
          "dryRun": true
        }
      }
    },
    {
      "id": "node_11",
      "type": "custom",
      "position": { "x": 700, "y": 650 },
      "data": {
        "type": "log_output",
        "label": "Log Article Dry Run",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "LinkedIn article dry run: success={{$json.success}} dryRun={{$json.dryRun}}"
        }
      }
    }
  ],
  "edges": [
    { "id": "edge_1", "source": "node_1", "target": "node_2" },
    { "id": "edge_2", "source": "node_2", "target": "node_3" },
    { "id": "edge_3", "source": "node_1", "target": "node_4" },
    { "id": "edge_4", "source": "node_4", "target": "node_5" },
    { "id": "edge_5", "source": "node_5", "target": "node_6" },
    { "id": "edge_6", "source": "node_6", "target": "node_7" },
    { "id": "edge_7", "source": "node_1", "target": "node_8" },
    { "id": "edge_8", "source": "node_8", "target": "node_9" },
    { "id": "edge_9", "source": "node_1", "target": "node_10" },
    { "id": "edge_10", "source": "node_10", "target": "node_11" }
  ],
  "viewport": { "x": 0, "y": 0, "zoom": 0.75 }
}
