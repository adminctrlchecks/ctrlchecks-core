{
  "name": "Test Instagram — Get Account + List Media + Get Insights",
  "description": "Tests Instagram account info, media listing, and insights. Requires Facebook account with Instagram Business/Creator account connected in /connections.",
  "nodes": [
    {
      "id": "node_1",
      "type": "custom",
      "position": { "x": 100, "y": 300 },
      "data": {
        "type": "manual_trigger",
        "label": "Start Test",
        "category": "triggers",
        "icon": "Play",
        "config": {}
      }
    },
    {
      "id": "node_2",
      "type": "custom",
      "position": { "x": 400, "y": 150 },
      "data": {
        "type": "instagram",
        "label": "Instagram — Get Account Info",
        "category": "social",
        "icon": "Instagram",
        "config": {
          "resource": "user",
          "operation": "get",
          "fields": "id,username,name,biography,followers_count,follows_count,media_count,profile_picture_url,website"
        }
      }
    },
    {
      "id": "node_3",
      "type": "custom",
      "position": { "x": 700, "y": 150 },
      "data": {
        "type": "log_output",
        "label": "Log: Account Info",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Instagram Account → username={{$json.username}} | followers={{$json.followers_count}} | media={{$json.media_count}}"
        }
      }
    },
    {
      "id": "node_4",
      "type": "custom",
      "position": { "x": 400, "y": 350 },
      "data": {
        "type": "instagram",
        "label": "Instagram — List Media Posts",
        "category": "social",
        "icon": "Image",
        "config": {
          "resource": "media",
          "operation": "list",
          "limit": 10,
          "fields": "id,caption,media_type,timestamp,permalink,thumbnail_url"
        }
      }
    },
    {
      "id": "node_5",
      "type": "custom",
      "position": { "x": 700, "y": 350 },
      "data": {
        "type": "log_output",
        "label": "Log: Media List",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Instagram Media → count={{$json.data.length}} | first post id={{$json.data[0].id}} | type={{$json.data[0].media_type}}"
        }
      }
    },
    {
      "id": "node_6",
      "type": "custom",
      "position": { "x": 400, "y": 550 },
      "data": {
        "type": "instagram",
        "label": "Instagram — Get Account Insights",
        "category": "social",
        "icon": "BarChart2",
        "config": {
          "resource": "insights",
          "operation": "get",
          "metric": "impressions,reach,profile_views",
          "period": "day"
        }
      }
    },
    {
      "id": "node_7",
      "type": "custom",
      "position": { "x": 700, "y": 550 },
      "data": {
        "type": "log_output",
        "label": "Log: Insights",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Instagram Insights → data returned, first metric: {{$json.data[0].name}}"
        }
      }
    }
  ],
  "edges": [
    { "id": "edge_1", "source": "node_1", "target": "node_2" },
    { "id": "edge_2", "source": "node_2", "target": "node_3" },
    { "id": "edge_3", "source": "node_1", "target": "node_4" },
    { "id": "edge_4", "source": "node_4", "target": "node_5" },
    { "id": "edge_5", "source": "node_1", "target": "node_6" },
    { "id": "edge_6", "source": "node_6", "target": "node_7" }
  ],
  "viewport": { "x": 0, "y": 0, "zoom": 0.85 }
}
