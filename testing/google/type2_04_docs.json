{
  "name": "Test Google Docs — Get + Create",
  "description": "Tests reading an existing Google Doc and creating a new one. Requires Google account connected in /connections.",
  "nodes": [
    {
      "id": "node_1",
      "type": "custom",
      "position": { "x": 100, "y": 250 },
      "data": {
        "type": "manual_trigger",
        "label": "Start Test",
        "category": "triggers",
        "icon": "Play",
        "config": {}
      }
    },
    {
      "id": "node_2",
      "type": "custom",
      "position": { "x": 400, "y": 150 },
      "data": {
        "type": "google_doc",
        "label": "Docs — Create New Document",
        "category": "documents",
        "icon": "FileText",
        "config": {
          "operation": "create",
          "title": "ctrlchecks Test Document",
          "content": "This document was created by the ctrlchecks workflow platform for testing purposes. Safe to delete."
        }
      }
    },
    {
      "id": "node_3",
      "type": "custom",
      "position": { "x": 700, "y": 150 },
      "data": {
        "type": "log_output",
        "label": "Log: Create Result",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Doc Create → documentId={{$json.documentId}} | title={{$json.title}}"
        }
      }
    },
    {
      "id": "node_4",
      "type": "custom",
      "position": { "x": 400, "y": 350 },
      "data": {
        "type": "google_doc",
        "label": "Docs — Get Document by ID",
        "category": "documents",
        "icon": "FileText",
        "config": {
          "operation": "read",
          "documentId": "{{$json.documentId}}"
        }
      }
    },
    {
      "id": "node_5",
      "type": "custom",
      "position": { "x": 700, "y": 350 },
      "data": {
        "type": "log_output",
        "label": "Log: Get Result",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Doc Get → documentId={{$json.documentId}} | title={{$json.title}} | revisionId={{$json.revisionId}}"
        }
      }
    }
  ],
  "edges": [
    { "id": "edge_1", "source": "node_1", "target": "node_2" },
    { "id": "edge_2", "source": "node_2", "target": "node_3" },
    { "id": "edge_3", "source": "node_2", "target": "node_4" },
    { "id": "edge_4", "source": "node_4", "target": "node_5" }
  ],
  "viewport": { "x": 0, "y": 0, "zoom": 0.9 }
}
