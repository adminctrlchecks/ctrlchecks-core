{
  "name": "Test Google Tasks — Full CRUD Chain",
  "description": "Full Create → Read → Update (complete) → Delete chain for Google Tasks. Requires Google account connected with Tasks scope.",
  "nodes": [
    {
      "id": "node_1",
      "type": "custom",
      "position": { "x": 100, "y": 300 },
      "data": {
        "type": "manual_trigger",
        "label": "Start CRUD Test",
        "category": "triggers",
        "icon": "Play",
        "config": {}
      }
    },
    {
      "id": "node_2",
      "type": "custom",
      "position": { "x": 380, "y": 300 },
      "data": {
        "type": "google_tasks",
        "label": "Tasks — CREATE Test Task",
        "category": "google",
        "icon": "CheckSquare",
        "config": {
          "operation": "create",
          "taskListId": "@default",
          "title": "ctrlchecks Test Task (safe to delete)",
          "notes": "This task was created by the ctrlchecks workflow platform for testing purposes.",
          "due": "2026-12-31"
        }
      }
    },
    {
      "id": "node_3",
      "type": "custom",
      "position": { "x": 660, "y": 300 },
      "data": {
        "type": "log_output",
        "label": "Log: Created",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Task Created → id={{$json.data.id}} | title={{$json.data.title}} | status={{$json.data.status}}"
        }
      }
    },
    {
      "id": "node_4",
      "type": "custom",
      "position": { "x": 940, "y": 300 },
      "data": {
        "type": "google_tasks",
        "label": "Tasks — READ Created Task",
        "category": "google",
        "icon": "Eye",
        "config": {
          "operation": "read",
          "taskListId": "@default",
          "taskId": "{{$json.data.id}}"
        }
      }
    },
    {
      "id": "node_5",
      "type": "custom",
      "position": { "x": 1220, "y": 300 },
      "data": {
        "type": "google_tasks",
        "label": "Tasks — UPDATE Mark Completed",
        "category": "google",
        "icon": "CheckCircle",
        "config": {
          "operation": "update",
          "taskListId": "@default",
          "taskId": "{{$json.data.id}}",
          "title": "ctrlchecks Test Task UPDATED",
          "notes": "Updated by ctrlchecks test workflow.",
          "status": "completed"
        }
      }
    },
    {
      "id": "node_6",
      "type": "custom",
      "position": { "x": 1500, "y": 300 },
      "data": {
        "type": "google_tasks",
        "label": "Tasks — DELETE Test Task",
        "category": "google",
        "icon": "Trash2",
        "config": {
          "operation": "delete",
          "taskListId": "@default",
          "taskId": "{{$json.data.id}}"
        }
      }
    },
    {
      "id": "node_7",
      "type": "custom",
      "position": { "x": 1780, "y": 300 },
      "data": {
        "type": "log_output",
        "label": "Log: CRUD Complete",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Tasks CRUD Complete → deleted={{$json.data.deleted}} | taskId={{$json.data.taskId}}"
        }
      }
    },
    {
      "id": "node_8",
      "type": "custom",
      "position": { "x": 380, "y": 500 },
      "data": {
        "type": "google_tasks",
        "label": "Tasks — LIST All Tasks",
        "category": "google",
        "icon": "List",
        "config": {
          "operation": "read",
          "taskListId": "@default"
        }
      }
    },
    {
      "id": "node_9",
      "type": "custom",
      "position": { "x": 660, "y": 500 },
      "data": {
        "type": "log_output",
        "label": "Log: List Result",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Tasks List → items count={{$json.data.items.length}} | kind={{$json.data.kind}}"
        }
      }
    }
  ],
  "edges": [
    { "id": "edge_1", "source": "node_1", "target": "node_2" },
    { "id": "edge_2", "source": "node_2", "target": "node_3" },
    { "id": "edge_3", "source": "node_2", "target": "node_4" },
    { "id": "edge_4", "source": "node_4", "target": "node_5" },
    { "id": "edge_5", "source": "node_5", "target": "node_6" },
    { "id": "edge_6", "source": "node_6", "target": "node_7" },
    { "id": "edge_7", "source": "node_1", "target": "node_8" },
    { "id": "edge_8", "source": "node_8", "target": "node_9" }
  ],
  "viewport": { "x": 0, "y": 0, "zoom": 0.6 }
}
