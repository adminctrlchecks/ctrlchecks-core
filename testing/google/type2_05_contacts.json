{
  "name": "Test Google Contacts — Full CRUD Chain",
  "description": "Full Create → Read → Update → Delete chain for Google Contacts. Each step uses the output of the previous step to pass the contact ID. Requires Google account connected.",
  "nodes": [
    {
      "id": "node_1",
      "type": "custom",
      "position": { "x": 100, "y": 300 },
      "data": {
        "type": "manual_trigger",
        "label": "Start CRUD Test",
        "category": "triggers",
        "icon": "Play",
        "config": {}
      }
    },
    {
      "id": "node_2",
      "type": "custom",
      "position": { "x": 380, "y": 300 },
      "data": {
        "type": "google_contacts",
        "label": "Contacts — CREATE Test Contact",
        "category": "google",
        "icon": "UserPlus",
        "config": {
          "operation": "create",
          "name": "ctrlchecks Test User",
          "email": "ctrltest_delete_me@example.com",
          "phone": "+15550000001"
        }
      }
    },
    {
      "id": "node_3",
      "type": "custom",
      "position": { "x": 660, "y": 300 },
      "data": {
        "type": "log_output",
        "label": "Log: Created",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Contact Created → resourceName={{$json.data.resourceName}} | etag={{$json.data.etag}}"
        }
      }
    },
    {
      "id": "node_4",
      "type": "custom",
      "position": { "x": 940, "y": 300 },
      "data": {
        "type": "google_contacts",
        "label": "Contacts — READ Created Contact",
        "category": "google",
        "icon": "User",
        "config": {
          "operation": "read",
          "contactId": "{{$json.data.resourceName}}"
        }
      }
    },
    {
      "id": "node_5",
      "type": "custom",
      "position": { "x": 1220, "y": 300 },
      "data": {
        "type": "google_contacts",
        "label": "Contacts — UPDATE Name + Email",
        "category": "google",
        "icon": "UserCheck",
        "config": {
          "operation": "update",
          "contactId": "{{$json.data.resourceName}}",
          "etag": "{{$json.data.etag}}",
          "name": "ctrlchecks Test User UPDATED",
          "email": "ctrltest_updated@example.com",
          "phone": "+15550000002"
        }
      }
    },
    {
      "id": "node_6",
      "type": "custom",
      "position": { "x": 1500, "y": 300 },
      "data": {
        "type": "google_contacts",
        "label": "Contacts — DELETE Test Contact",
        "category": "google",
        "icon": "UserMinus",
        "config": {
          "operation": "delete",
          "contactId": "{{$json.data.resourceName}}"
        }
      }
    },
    {
      "id": "node_7",
      "type": "custom",
      "position": { "x": 1780, "y": 300 },
      "data": {
        "type": "log_output",
        "label": "Log: CRUD Complete",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Contacts CRUD Complete → deleted={{$json.data.deleted}} | contactId={{$json.data.contactId}}"
        }
      }
    },
    {
      "id": "node_8",
      "type": "custom",
      "position": { "x": 380, "y": 500 },
      "data": {
        "type": "google_contacts",
        "label": "Contacts — LIST All Contacts",
        "category": "google",
        "icon": "Users",
        "config": {
          "operation": "read",
          "pageSize": 10
        }
      }
    },
    {
      "id": "node_9",
      "type": "custom",
      "position": { "x": 660, "y": 500 },
      "data": {
        "type": "log_output",
        "label": "Log: List Result",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Contacts List → totalPeople={{$json.data.totalPeople}} | connections returned={{$json.data.connections.length}}"
        }
      }
    }
  ],
  "edges": [
    { "id": "edge_1", "source": "node_1", "target": "node_2" },
    { "id": "edge_2", "source": "node_2", "target": "node_3" },
    { "id": "edge_3", "source": "node_2", "target": "node_4" },
    { "id": "edge_4", "source": "node_4", "target": "node_5" },
    { "id": "edge_5", "source": "node_5", "target": "node_6" },
    { "id": "edge_6", "source": "node_6", "target": "node_7" },
    { "id": "edge_7", "source": "node_1", "target": "node_8" },
    { "id": "edge_8", "source": "node_8", "target": "node_9" }
  ],
  "viewport": { "x": 0, "y": 0, "zoom": 0.6 }
}
