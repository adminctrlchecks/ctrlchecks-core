{
  "name": "Test Google Drive — List + Upload + Download",
  "description": "Lists Drive files, uploads a test file, then downloads it by ID. Upload and download are chained directly (download reads fileId from upload's rawInput output). Requires Google account connected.",
  "nodes": [
    {
      "id": "node_1",
      "type": "custom",
      "position": { "x": 100, "y": 300 },
      "data": {
        "type": "manual_trigger",
        "label": "Start Test",
        "category": "triggers",
        "icon": "Play",
        "config": {}
      }
    },
    {
      "id": "node_2",
      "type": "custom",
      "position": { "x": 400, "y": 300 },
      "data": {
        "type": "google_drive",
        "label": "Drive — List Files",
        "category": "storage",
        "icon": "FolderOpen",
        "config": {
          "operation": "list",
          "pageSize": 10
        }
      }
    },
    {
      "id": "node_3",
      "type": "custom",
      "position": { "x": 700, "y": 300 },
      "data": {
        "type": "log_output",
        "label": "Log: List Files",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Drive List → files loaded in data.files array"
        }
      }
    },
    {
      "id": "node_4",
      "type": "custom",
      "position": { "x": 1000, "y": 300 },
      "data": {
        "type": "google_drive",
        "label": "Drive — Upload Test File",
        "category": "storage",
        "icon": "Upload",
        "config": {
          "operation": "upload",
          "fileName": "ctrlchecks-test-upload.txt",
          "fileData": "This is a test file uploaded by the ctrlchecks workflow platform.",
          "mimeType": "text/plain"
        }
      }
    },
    {
      "id": "node_5",
      "type": "custom",
      "position": { "x": 1300, "y": 300 },
      "data": {
        "type": "google_drive",
        "label": "Drive — Download Uploaded File",
        "category": "storage",
        "icon": "Download",
        "config": {
          "operation": "download",
          "fileId": "{{data.id}}"
        }
      }
    },
    {
      "id": "node_6",
      "type": "custom",
      "position": { "x": 1600, "y": 300 },
      "data": {
        "type": "log_output",
        "label": "Log: Upload + Download Result",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Drive Download complete — file content retrieved"
        }
      }
    }
  ],
  "edges": [
    { "id": "edge_1", "source": "node_1", "target": "node_2" },
    { "id": "edge_2", "source": "node_2", "target": "node_3" },
    { "id": "edge_3", "source": "node_3", "target": "node_4" },
    { "id": "edge_4", "source": "node_4", "target": "node_5" },
    { "id": "edge_5", "source": "node_5", "target": "node_6" }
  ],
  "viewport": { "x": 0, "y": 0, "zoom": 0.75 }
}
