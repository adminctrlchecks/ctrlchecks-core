{
  "name": "Test Google Sheets - Read + Append",
  "description": "Tests reading a range from a sheet, then appending a new row. Sequential chain. Requires Google account connected with Sheets scopes.",
  "nodes": [
    {
      "id": "node_1",
      "type": "custom",
      "position": { "x": 100, "y": 300 },
      "data": {
        "type": "manual_trigger",
        "label": "Start Test",
        "category": "triggers",
        "icon": "Play",
        "config": {}
      }
    },
    {
      "id": "node_2",
      "type": "custom",
      "position": { "x": 400, "y": 300 },
      "data": {
        "type": "google_sheets",
        "label": "Sheets - Read Range",
        "category": "productivity",
        "icon": "Table",
        "config": {
          "operation": "read",
          "spreadsheetId": "1a-FG5aWi1u77OrGW2j-D2imjSgvy4mtmMfqusmlhhsM",
          "sheetName": "Test",
          "range": "A1:C10"
        }
      }
    },
    {
      "id": "node_3",
      "type": "custom",
      "position": { "x": 700, "y": 300 },
      "data": {
        "type": "log_output",
        "label": "Log: Read Result",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Sheets Read -> count={{rows.length}} | headers={{headers.length}}"
        }
      }
    },
    {
      "id": "node_4",
      "type": "custom",
      "position": { "x": 1000, "y": 300 },
      "data": {
        "type": "google_sheets",
        "label": "Sheets - Append Row",
        "category": "productivity",
        "icon": "PlusSquare",
        "config": {
          "operation": "append",
          "spreadsheetId": "1a-FG5aWi1u77OrGW2j-D2imjSgvy4mtmMfqusmlhhsM",
          "sheetName": "Test",
          "range": "A:C",
          "data": [["Charlie", "charlie@example.com", 91]]
        }
      }
    },
    {
      "id": "node_5",
      "type": "custom",
      "position": { "x": 1300, "y": 300 },
      "data": {
        "type": "log_output",
        "label": "Log: Append Result",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Sheets Append -> updatedRange={{updatedRange}} | updatedRows={{updatedRows}} | updatedCells={{updatedCells}}"
        }
      }
    }
  ],
  "edges": [
    { "id": "edge_1", "source": "node_1", "target": "node_2" },
    { "id": "edge_2", "source": "node_2", "target": "node_3" },
    { "id": "edge_3", "source": "node_3", "target": "node_4" },
    { "id": "edge_4", "source": "node_4", "target": "node_5" }
  ],
  "viewport": { "x": 0, "y": 0, "zoom": 0.8 }
}
