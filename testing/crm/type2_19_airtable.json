{
  "name": "Test Airtable — Full CRUD Chain",
  "description": "Full List → Create → Update → Delete chain for Airtable records. REQUIRED: Replace YOUR_BASE_ID and YOUR_TABLE_NAME with your actual Airtable base ID and table name. Requires Airtable personal access token in /connections.",
  "nodes": [
    {
      "id": "node_1",
      "type": "custom",
      "position": { "x": 100, "y": 300 },
      "data": {
        "type": "manual_trigger",
        "label": "Start CRUD Test",
        "category": "triggers",
        "icon": "Play",
        "config": {}
      }
    },
    {
      "id": "node_2",
      "type": "custom",
      "position": { "x": 400, "y": 150 },
      "data": {
        "type": "airtable",
        "label": "Airtable — LIST Records (first 5)",
        "category": "data",
        "icon": "Table",
        "config": {
          "operation": "list",
          "baseId": "YOUR_BASE_ID",
          "table": "YOUR_TABLE_NAME",
          "maxRecords": 5
        }
      }
    },
    {
      "id": "node_3",
      "type": "custom",
      "position": { "x": 700, "y": 150 },
      "data": {
        "type": "log_output",
        "label": "Log: List",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Airtable List → records={{$json.records.length}} | first id={{$json.records[0].id}}"
        }
      }
    },
    {
      "id": "node_4",
      "type": "custom",
      "position": { "x": 400, "y": 350 },
      "data": {
        "type": "airtable",
        "label": "Airtable — CREATE Test Record",
        "category": "data",
        "icon": "PlusCircle",
        "config": {
          "operation": "create",
          "baseId": "YOUR_BASE_ID",
          "table": "YOUR_TABLE_NAME",
          "fields": {
            "Name": "ctrlchecks Test Record",
            "Notes": "Created by ctrlchecks workflow platform. Safe to delete.",
            "Status": "In progress"
          }
        }
      }
    },
    {
      "id": "node_5",
      "type": "custom",
      "position": { "x": 700, "y": 350 },
      "data": {
        "type": "log_output",
        "label": "Log: Created",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Airtable Created → id={{$json.id}} | Name={{$json.fields.Name}}"
        }
      }
    },
    {
      "id": "node_6",
      "type": "custom",
      "position": { "x": 1000, "y": 350 },
      "data": {
        "type": "airtable",
        "label": "Airtable — UPDATE Record",
        "category": "data",
        "icon": "Edit",
        "config": {
          "operation": "update",
          "baseId": "YOUR_BASE_ID",
          "table": "YOUR_TABLE_NAME",
          "recordId": "{{$json.id}}",
          "fields": {
            "Name": "ctrlchecks Test Record UPDATED",
            "Notes": "Updated by ctrlchecks workflow platform.",
            "Status": "Done"
          }
        }
      }
    },
    {
      "id": "node_7",
      "type": "custom",
      "position": { "x": 1300, "y": 350 },
      "data": {
        "type": "log_output",
        "label": "Log: Updated",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Airtable Updated → id={{$json.id}} | Name={{$json.fields.Name}} | Status={{$json.fields.Status}}"
        }
      }
    },
    {
      "id": "node_8",
      "type": "custom",
      "position": { "x": 1600, "y": 350 },
      "data": {
        "type": "airtable",
        "label": "Airtable — DELETE Record",
        "category": "data",
        "icon": "Trash2",
        "config": {
          "operation": "delete",
          "baseId": "YOUR_BASE_ID",
          "table": "YOUR_TABLE_NAME",
          "recordId": "{{$json.id}}"
        }
      }
    },
    {
      "id": "node_9",
      "type": "custom",
      "position": { "x": 1900, "y": 350 },
      "data": {
        "type": "log_output",
        "label": "Log: CRUD Complete",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Airtable CRUD Complete → deleted={{$json.deleted}} | id={{$json.id}}"
        }
      }
    }
  ],
  "edges": [
    { "id": "edge_1", "source": "node_1", "target": "node_2" },
    { "id": "edge_2", "source": "node_2", "target": "node_3" },
    { "id": "edge_3", "source": "node_1", "target": "node_4" },
    { "id": "edge_4", "source": "node_4", "target": "node_5" },
    { "id": "edge_5", "source": "node_4", "target": "node_6" },
    { "id": "edge_6", "source": "node_6", "target": "node_7" },
    { "id": "edge_7", "source": "node_6", "target": "node_8" },
    { "id": "edge_8", "source": "node_8", "target": "node_9" }
  ],
  "viewport": { "x": 0, "y": 0, "zoom": 0.6 }
}
