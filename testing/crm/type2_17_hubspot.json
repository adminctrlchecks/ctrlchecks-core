{
  "name": "Test HubSpot - Contacts and Companies",
  "description": "HubSpot smoke workflow for resource-aware Contacts and Companies. Requires a user-owned HubSpot connection in /connections.",
  "nodes": [
    {
      "id": "node_1",
      "type": "custom",
      "position": { "x": 100, "y": 500 },
      "data": {
        "type": "manual_trigger",
        "label": "Start Test",
        "category": "triggers",
        "icon": "Play",
        "config": {}
      }
    },
    {
      "id": "node_2",
      "type": "custom",
      "position": { "x": 400, "y": 120 },
      "data": {
        "type": "hubspot",
        "label": "HubSpot - List 5 Contacts",
        "category": "crm",
        "icon": "Users",
        "config": {
          "resource": "contact",
          "operation": "getMany",
          "limit": 5
        }
      }
    },
    {
      "id": "node_3",
      "type": "custom",
      "position": { "x": 700, "y": 120 },
      "data": {
        "type": "log_output",
        "label": "Log: Contacts List",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "HubSpot Contacts -> total={{$json.total}} | first contact email={{$json.results[0].properties.email}}"
        }
      }
    },
    {
      "id": "node_4",
      "type": "custom",
      "position": { "x": 400, "y": 330 },
      "data": {
        "type": "hubspot",
        "label": "HubSpot - Create Test Contact",
        "category": "crm",
        "icon": "UserPlus",
        "config": {
          "resource": "contact",
          "operation": "create",
          "properties": {
            "email": "ctrltest_delete_me@example.com",
            "firstname": "CtrlChecks",
            "lastname": "TestUser",
            "phone": "+15550000001",
            "company": "CtrlChecks Test Corp",
            "hs_lead_status": "NEW"
          }
        }
      }
    },
    {
      "id": "node_5",
      "type": "custom",
      "position": { "x": 700, "y": 330 },
      "data": {
        "type": "log_output",
        "label": "Log: Created Contact",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "HubSpot Contact Created -> id={{$json.id}} | email={{$json.properties.email}}"
        }
      }
    },
    {
      "id": "node_6",
      "type": "custom",
      "position": { "x": 1000, "y": 330 },
      "data": {
        "type": "hubspot",
        "label": "HubSpot - Get Created Contact",
        "category": "crm",
        "icon": "User",
        "config": {
          "resource": "contact",
          "operation": "get",
          "id": "{{$json.id}}"
        }
      }
    },
    {
      "id": "node_7",
      "type": "custom",
      "position": { "x": 1300, "y": 330 },
      "data": {
        "type": "hubspot",
        "label": "HubSpot - Update Contact Phone",
        "category": "crm",
        "icon": "Edit",
        "config": {
          "resource": "contact",
          "operation": "update",
          "id": "{{$json.id}}",
          "properties": {
            "phone": "+15550000099",
            "company": "CtrlChecks Test Corp Updated"
          }
        }
      }
    },
    {
      "id": "node_8",
      "type": "custom",
      "position": { "x": 1600, "y": 330 },
      "data": {
        "type": "hubspot",
        "label": "HubSpot - Delete Test Contact",
        "category": "crm",
        "icon": "Trash2",
        "config": {
          "resource": "contact",
          "operation": "delete",
          "id": "{{$json.id}}"
