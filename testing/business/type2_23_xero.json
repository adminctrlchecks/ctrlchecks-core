{
  "name": "Test Xero — Get Organisation + List Invoices + List Contacts",
  "description": "Tests Xero organisation info, invoice listing, and contact listing. Requires Xero OAuth connected in /connections. Fill in tenantId.",
  "nodes": [
    {
      "id": "node_1",
      "type": "custom",
      "position": { "x": 100, "y": 350 },
      "data": {
        "type": "manual_trigger",
        "label": "Start Test",
        "category": "triggers",
        "icon": "Play",
        "config": {}
      }
    },
    {
      "id": "node_2",
      "type": "custom",
      "position": { "x": 400, "y": 150 },
      "data": {
        "type": "xero",
        "label": "Xero — Get Organisation",
        "category": "accounting",
        "icon": "Building",
        "config": {
          "operation": "getOrganisation",
          "tenantId": "YOUR_XERO_TENANT_ID"
        }
      }
    },
    {
      "id": "node_3",
      "type": "custom",
      "position": { "x": 700, "y": 150 },
      "data": {
        "type": "log_output",
        "label": "Log: Organisation",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Xero Org → Name={{$json.Organisations[0].Name}} | OrganisationID={{$json.Organisations[0].OrganisationID}} | BaseCurrency={{$json.Organisations[0].BaseCurrency}}"
        }
      }
    },
    {
      "id": "node_4",
      "type": "custom",
      "position": { "x": 400, "y": 350 },
      "data": {
        "type": "xero",
        "label": "Xero — List Recent Invoices",
        "category": "accounting",
        "icon": "FileText",
        "config": {
          "operation": "listInvoices",
          "tenantId": "YOUR_XERO_TENANT_ID",
          "page": 1,
          "where": "Type=\"ACCREC\" AND Status!=\"VOIDED\"",
          "order": "Date DESC"
        }
      }
    },
    {
      "id": "node_5",
      "type": "custom",
      "position": { "x": 700, "y": 350 },
      "data": {
        "type": "log_output",
        "label": "Log: Invoices",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Xero Invoices → count={{$json.Invoices.length}} | first: {{$json.Invoices[0].InvoiceNumber}} (${{$json.Invoices[0].Total}} {{$json.Invoices[0].CurrencyCode}})"
        }
      }
    },
    {
      "id": "node_6",
      "type": "custom",
      "position": { "x": 400, "y": 550 },
      "data": {
        "type": "xero",
        "label": "Xero — List Accounts (Chart)",
        "category": "accounting",
        "icon": "BarChart",
        "config": {
          "operation": "getAccounts",
          "tenantId": "YOUR_XERO_TENANT_ID"
        }
      }
    },
    {
      "id": "node_7",
      "type": "custom",
      "position": { "x": 700, "y": 550 },
      "data": {
        "type": "log_output",
        "label": "Log: Accounts",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Xero Accounts → count={{$json.Accounts.length}} | first: {{$json.Accounts[0].Name}} ({{$json.Accounts[0].Type}})"
        }
      }
    }
  ],
  "edges": [
    { "id": "edge_1", "source": "node_1", "target": "node_2" },
    { "id": "edge_2", "source": "node_2", "target": "node_3" },
    { "id": "edge_3", "source": "node_1", "target": "node_4" },
    { "id": "edge_4", "source": "node_4", "target": "node_5" },
    { "id": "edge_5", "source": "node_1", "target": "node_6" },
    { "id": "edge_6", "source": "node_6", "target": "node_7" }
  ],
  "viewport": { "x": 0, "y": 0, "zoom": 0.85 }
}
