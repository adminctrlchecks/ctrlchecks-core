{
  "name": "Test Microsoft Dynamics — List Accounts + Contacts + Leads",
  "description": "Tests listing key Dynamics 365 CRM entities. Requires Microsoft account connected in /connections with Dynamics permissions. Fill in organizationUrl.",
  "nodes": [
    {
      "id": "node_1",
      "type": "custom",
      "position": { "x": 100, "y": 350 },
      "data": {
        "type": "manual_trigger",
        "label": "Start Test",
        "category": "triggers",
        "icon": "Play",
        "config": {}
      }
    },
    {
      "id": "node_2",
      "type": "custom",
      "position": { "x": 400, "y": 150 },
      "data": {
        "type": "microsoft_dynamics",
        "label": "Dynamics — List 5 Accounts",
        "category": "crm",
        "icon": "Building",
        "config": {
          "operation": "list",
          "entity": "accounts",
          "organizationUrl": "YOUR_DYNAMICS_ORG_URL",
          "top": 5,
          "select": "name,telephone1,emailaddress1,websiteurl"
        }
      }
    },
    {
      "id": "node_3",
      "type": "custom",
      "position": { "x": 700, "y": 150 },
      "data": {
        "type": "log_output",
        "label": "Log: Accounts",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "Dynamics Accounts → count={{$json.value.length}} | first: {{$json.value[0].name}}"
        }
      }
    },
    {
      "id": "node_4",
      "type": "custom",
      "position": { "x": 400, "y": 350 },
      "data": {
        "type": "microsoft_dynamics",
        "label": "Dynamics — List 5 Contacts",
        "category": "crm",
        "icon": "User",
        "config": {
