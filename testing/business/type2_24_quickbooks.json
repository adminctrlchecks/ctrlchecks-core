{
  "name": "Test QuickBooks (Intuit) — Company Info + Customers + Invoices",
  "description": "Tests QuickBooks company info, customer listing, and invoice listing. Requires Intuit/QuickBooks OAuth connected in /connections. Fill in realmId.",
  "nodes": [
    {
      "id": "node_1",
      "type": "custom",
      "position": { "x": 100, "y": 350 },
      "data": {
        "type": "manual_trigger",
        "label": "Start Test",
        "category": "triggers",
        "icon": "Play",
        "config": {}
      }
    },
    {
      "id": "node_2",
      "type": "custom",
      "position": { "x": 400, "y": 150 },
      "data": {
        "type": "intuit_smes",
        "label": "QuickBooks — Get Company Info",
        "category": "accounting",
        "icon": "Building2",
        "config": {
          "operation": "getCompanyInfo",
          "realmId": "YOUR_QUICKBOOKS_REALM_ID"
        }
      }
    },
    {
      "id": "node_3",
      "type": "custom",
      "position": { "x": 700, "y": 150 },
      "data": {
        "type": "log_output",
        "label": "Log: Company Info",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "QuickBooks Company → CompanyName={{$json.QueryResponse.CompanyInfo[0].CompanyName}} | Country={{$json.QueryResponse.CompanyInfo[0].Country}}"
        }
      }
    },
    {
      "id": "node_4",
      "type": "custom",
      "position": { "x": 400, "y": 350 },
      "data": {
        "type": "intuit_smes",
        "label": "QuickBooks — List Customers",
        "category": "accounting",
        "icon": "Users",
        "config": {
          "operation": "listCustomers",
          "realmId": "YOUR_QUICKBOOKS_REALM_ID",
          "maxResults": 10
        }
      }
    },
    {
      "id": "node_5",
      "type": "custom",
      "position": { "x": 700, "y": 350 },
      "data": {
        "type": "log_output",
        "label": "Log: Customers",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "QuickBooks Customers → count={{$json.QueryResponse.totalCount}} | first: {{$json.QueryResponse.Customer[0].DisplayName}}"
        }
      }
    },
    {
      "id": "node_6",
      "type": "custom",
      "position": { "x": 400, "y": 550 },
      "data": {
        "type": "intuit_smes",
        "label": "QuickBooks — List Invoices",
        "category": "accounting",
        "icon": "FileText",
        "config": {
          "operation": "listInvoices",
          "realmId": "YOUR_QUICKBOOKS_REALM_ID",
          "maxResults": 10
        }
      }
    },
    {
      "id": "node_7",
      "type": "custom",
      "position": { "x": 700, "y": 550 },
      "data": {
        "type": "log_output",
        "label": "Log: Invoices",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "QuickBooks Invoices → count={{$json.QueryResponse.totalCount}} | first: #{{$json.QueryResponse.Invoice[0].DocNumber}} (${{$json.QueryResponse.Invoice[0].TotalAmt}})"
        }
      }
    }
  ],
  "edges": [
    { "id": "edge_1", "source": "node_1", "target": "node_2" },
    { "id": "edge_2", "source": "node_2", "target": "node_3" },
    { "id": "edge_3", "source": "node_1", "target": "node_4" },
    { "id": "edge_4", "source": "node_4", "target": "node_5" },
    { "id": "edge_5", "source": "node_1", "target": "node_6" },
    { "id": "edge_6", "source": "node_6", "target": "node_7" }
  ],
  "viewport": { "x": 0, "y": 0, "zoom": 0.85 }
}
