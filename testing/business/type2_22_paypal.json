{
  "name": "Test PayPal — Get Profile + List Transactions",
  "description": "Tests PayPal account profile and transaction listing. Requires PayPal OAuth connected in /connections.",
  "nodes": [
    {
      "id": "node_1",
      "type": "custom",
      "position": { "x": 100, "y": 250 },
      "data": {
        "type": "manual_trigger",
        "label": "Start Test",
        "category": "triggers",
        "icon": "Play",
        "config": {}
      }
    },
    {
      "id": "node_2",
      "type": "custom",
      "position": { "x": 400, "y": 150 },
      "data": {
        "type": "paypal",
        "label": "PayPal — Get Account Profile",
        "category": "payment",
        "icon": "CreditCard",
        "config": {
          "operation": "get_profile"
        }
      }
    },
    {
      "id": "node_3",
      "type": "custom",
      "position": { "x": 700, "y": 150 },
      "data": {
        "type": "log_output",
        "label": "Log: Profile",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "PayPal Profile → payer_id={{$json.payer_id}} | email={{$json.email}} | name={{$json.name.given_name}} {{$json.name.surname}}"
        }
      }
    },
    {
      "id": "node_4",
      "type": "custom",
      "position": { "x": 400, "y": 350 },
      "data": {
        "type": "paypal",
        "label": "PayPal — List Recent Transactions",
        "category": "payment",
        "icon": "DollarSign",
        "config": {
          "operation": "list_transactions",
          "start_date": "2026-01-01T00:00:00-0700",
          "end_date": "2026-12-31T23:59:59-0700",
          "page_size": 10
        }
      }
    },
    {
      "id": "node_5",
      "type": "custom",
      "position": { "x": 700, "y": 350 },
      "data": {
        "type": "log_output",
        "label": "Log: Transactions",
        "category": "output",
        "icon": "FileOutput",
        "config": {
          "level": "info",
          "message": "PayPal Transactions → total_items={{$json.total_items}} | total_pages={{$json.total_pages}} | first tx: {{$json.transaction_details[0].transaction_info.transaction_id}}"
        }
      }
    }
  ],
  "edges": [
    { "id": "edge_1", "source": "node_1", "target": "node_2" },
    { "id": "edge_2", "source": "node_2", "target": "node_3" },
    { "id": "edge_3", "source": "node_1", "target": "node_4" },
    { "id": "edge_4", "source": "node_4", "target": "node_5" }
  ],
  "viewport": { "x": 0, "y": 0, "zoom": 0.9 }
}
